# Cordelius Trading — Variables de entorno
# Copia este archivo a .env y rellena tus valores reales.
# NUNCA subas .env a git. Este archivo (.env.example) SÍ se sube.

# ── Puerto del servidor ──────────────────────────────────────────────────────
PORT=3000

# ── Tipo de cambio USD/MXN (actualizar manualmente) ──────────────────────────
USD_MXN=18.50

# ── API Keys (reemplaza los placeholders con tus claves reales) ───────────────

# Claude AI (Anthropic) — para Alfredo AI en el dashboard
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Bot — token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Finnhub — cotizaciones en tiempo real (opcional; sin clave usa valores manuales)
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxx

# ── Opcionales ────────────────────────────────────────────────────────────────

# Quiver Quantitative (reservado para futuro)
QUIVER_API_KEY=

# Modelo Claude a usar (default recomendado: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
